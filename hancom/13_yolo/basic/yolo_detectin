from ultralytics import YOLO
import cv2

#. 1  모델 로드 
model = YOLO("yolo11n.pt")

#. 2  모델 추론
results = model("input_det2.jpg")

#. 3  결과 시각화 
results_imge = results[0].plot()

#. 4  결과 이미지 저장
output_image_path = "./result_det2.jpg"
cv2.imwrite(output_image_path, results_imge)
print(f"사진이 저장 되었습니다. => {output_image_path}")